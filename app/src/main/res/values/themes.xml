<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SaQr" parent="Theme.AppCompat.DayNight">
        <item name="android:windowBackground">#FF0D1117</item>
        <item name="android:statusBarColor">#FF161B22</item>
        <item name="colorPrimary">#FF161B22</item>
        <item name="colorPrimaryDark">#FF0D1117</item>
        <item name="actionBarStyle">@style/SaQrActionBar</item>
    </style>

    <style name="SaQrActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">#FF161B22</item>
        <item name="titleTextStyle">@style/SaQrActionBarText</item>
    </style>

    <style name="SaQrActionBarText" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">#FF58A6FF</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SaQr" parent="Theme.AppCompat.DayNight">
        <item name="android:windowBackground">@color/windowBg</item>
        <item name="android:statusBarColor">@color/statusBarBg</item>
        <item name="colorPrimary">@color/primaryBg</item>
        <item name="colorPrimaryDark">@color/primaryDarkBg</item>
        <item name="actionBarStyle">@style/SaQrActionBar</item>
    </style>

    <style name="SaQrActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/primaryBg</item>
        <item name="titleTextStyle">@style/SaQrActionBarText</item>
    </style>

    <style name="SaQrActionBarText" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/titleText</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>
